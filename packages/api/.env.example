# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Get from: Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379

# AWS
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=veridian-documents

# Webhooks
WEBHOOK_SECRET=your-hmac-secret

# Paddle billing
PADDLE_API_KEY=your-paddle-production-api-key
PADDLE_SANDBOX_API_KEY=your-paddle-sandbox-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_CHECKOUT_URL=https://veridian-web-rho.vercel.app
PADDLE_PRICE_STARTER=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_GROWTH=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_SCALE=pri_xxxxxxxxxxxxxxxx
PADDLE_SANDBOX_PRICE_STARTER=pri_xxxxxxxxxxxxxxxx
PADDLE_SANDBOX_PRICE_GROWTH=pri_xxxxxxxxxxxxxxxx
PADDLE_SANDBOX_PRICE_SCALE=pri_xxxxxxxxxxxxxxxx

# Server
PORT=3001
